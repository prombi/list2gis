# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# uv
# (uv.lock SHOULD be committed for applications; keep it tracked)

# Project data — user's own CSV inputs, not shared
/input/

# User-created presets — only the example preset ships with the repo.
# Any preset files the user adds (via the download/import flow or by hand)
# stay local unless explicitly force-added.
/config/*
!/config/Example-Adressen-Kategorien.json

# Runtime caches (geocoding results, etc.)
/cache/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Streamlit
.streamlit/secrets.toml
streamlit.log

# Generated icon cache (regenerated from source on demand)
/assets/icons/

# Claude Code local settings (per-machine permissions)
.claude/settings.local.json
